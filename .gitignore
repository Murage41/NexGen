# =============================================================================
# NexGen — Monorepo .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------

# Vite (mobile)
mobile/dist/
mobile/.vite/

# Electron (desktop)
desktop/dist/
desktop/dist-electron/
desktop/out/
desktop/release/

# Backend compiled output
backend/dist/

# -----------------------------------------------------------------------------
# Database — NEVER commit the live database
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# Keep the data directory but not its contents
backend/data/*
!backend/data/.gitkeep

# -----------------------------------------------------------------------------
# Environment Variables
# -----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.production
.env.*.local

# Keep example files (safe to commit)
!.env.example
!.env.*.example

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# IDEs & Editors
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-workspace

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
.cache/
.turbo/
.eslintcache
.stylelintcache

# -----------------------------------------------------------------------------
# Electron Builder
# -----------------------------------------------------------------------------
desktop/build/installers/
desktop/*.exe
desktop/*.dmg
desktop/*.AppImage
desktop/*.deb
desktop/*.rpm
desktop/*.snap

# -----------------------------------------------------------------------------
# Ngrok (tunnel utility)
# -----------------------------------------------------------------------------
ngrok.log
ngrok.yml
.ngrok/

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# -----------------------------------------------------------------------------
# PM2 (process manager — server deployment)
# -----------------------------------------------------------------------------
.pm2/
ecosystem.config.js.bak

# Claude Code internal
.claude/
