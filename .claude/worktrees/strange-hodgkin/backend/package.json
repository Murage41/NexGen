{
  "name": "nexgen-backend",
  "version": "1.0.0",
  "description": "NexGen Backend API",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "knex migrate:latest --knexfile src/knexfile.ts",
    "migrate:make": "knex migrate:make --knexfile src/knexfile.ts",
    "seed": "knex seed:run --knexfile src/knexfile.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "knex": "^3.1.0",
    "sqlite3": "^5.1.7",
    "shared": "*"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
