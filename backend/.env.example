NODE_ENV=production
HOST=127.0.0.1
PORT=3001

# Generate a long random value before production use.
SESSION_SECRET=change-me-generate-32-plus-random-characters
SESSION_TTL_HOURS=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
LOGIN_LOCK_MINUTES=15

# Required for the current desktop app. Leave unset only for mobile-only/API-only deployments.
# The desktop build must use the same value as VITE_DESKTOP_KEY.
DESKTOP_KEY=change-me-generate-24-plus-random-characters

# Comma-separated browser origins allowed to call the API cross-origin.
# Leave blank when mobile is served from the backend at /mobile.
CORS_ORIGINS=

MAX_PUMP_LITRES_PER_SHIFT=10000
